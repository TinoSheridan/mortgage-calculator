{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pip install -r requirements.txt --no-cache-dir"
  },
  "deploy": {
    "startCommand": "gunicorn app:app --config gunicorn.conf.py",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 300
  }
}
